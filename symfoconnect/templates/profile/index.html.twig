{% extends 'base.html.twig' %}

{% block title %}Profil de {{ user.username }}{% endblock %}

{% block body %}
    <div class="card">
        {% if user.avatarUrl %}
            <img src="{{ user.avatarUrl }}" alt="Avatar" width="80" style="border-radius: 50%; margin-bottom: 10px;">
        {% else %}
            <div style="width:80px; height:80px; border-radius:50%; background:#1877f2; display:flex; align-items:center; justify-content:center; color:white; font-size:30px; margin-bottom:10px;">
                {{ user.username|slice(0,1)|upper }}
            </div>
        {% endif %}

        <h1>{{ user.username }}</h1>
        <p><strong>Email :</strong> {{ user.email }}</p>
        <p><strong>Membre depuis :</strong> {{ user.createdAt|date('d/m/Y') }}</p>

        {% if user.bio %}
            <p><strong>Bio :</strong> {{ user.bio }}</p>
        {% endif %}

        <p>
            <strong>👥 Followers :</strong> {{ user.followers|length }} &nbsp;|&nbsp;
            <strong>➡️ Abonnements :</strong> {{ user.following|length }}
        </p>

        {% if app.user and app.user.id != user.id %}
            {% if app.user.following.contains(user) %}
                <a href="{{ path('app_follow', {username: user.username}) }}" class="btn btn-unfollow">Ne plus suivre</a>
            {% else %}
                <a href="{{ path('app_follow', {username: user.username}) }}" class="btn btn-follow">➕ Suivre</a>
            {% endif %}
            <a href="{{ path('app_conversation', {username: user.username}) }}" class="btn btn-primary" style="margin-top:10px;">
                💬 Envoyer un message
            </a>
        {% endif %}
    </div>

    <h1>Posts de {{ user.username }}</h1>

    {% for post in user.posts %}
        <div class="card">
            <p>{{ post.content }}</p>
            <small>{{ post.createdAt|date('d/m/Y H:i') }}</small>
        </div>
    {% else %}
        <p>Aucun post pour le moment.</p>
    {% endfor %}
{% endblock %}